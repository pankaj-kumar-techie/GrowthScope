# Port to run the server on
PORT=3002

# Node environment (development or production)
NODE_ENV=development

# Anthropic API Key (Claude Sonnet/Haiku)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google PageSpeed Insights API Key
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Google Places API Key (Fallback for business search & website URLs)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Seoptimer API Key (If used by the scraper/auditor)
SEOPTIMER_API_KEY=your_seoptimer_api_key_here

# DataForSEO API Credentials (Used for SERP Google Maps and domain ranking/traffic)
DATAFORSEO_LOGIN=your_dataforseo_login_email_here
DATAFORSEO_PASSWORD=your_dataforseo_api_password_here

# ScreenshotOne API Key (Alternative for taking screenshots)
SCREENSHOTONE_API_KEY=your_screenshotone_api_key_here
